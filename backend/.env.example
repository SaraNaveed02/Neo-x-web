# Nexura Backend — copy to .env and fill values
APP_ENV=local
APP_DEBUG=false
APP_FORCE_HTTPS=false
APP_BASE_URL=http://localhost/time/backend

# MySQL
DB_HOST=localhost
DB_NAME=nexura_db
DB_USER=root
DB_PASS=

# JWT / session (change in production)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_TTL=604800

# Token encryption key (32+ chars — used to encrypt Microsoft tokens at rest)
TOKEN_ENCRYPTION_KEY=change-this-32-char-minimum-secret-key!!

# Microsoft Azure AD / Graph OAuth 2.0
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost/time/backend/api/microsoft/callback.php

# Comma-separated delegated scopes (user consent required)
MICROSOFT_SCOPES=openid profile offline_access User.Read Mail.Read
